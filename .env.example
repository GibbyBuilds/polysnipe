# Polymarket BTC Bot — Environment Variables
# Copy this to .env and fill in your values

# Wallet credentials (run setup_creds.py to generate)
POLY_PRIVATE_KEY=0x_your_private_key
POLY_FUNDER_ADDRESS=your_funder_address
POLY_SIGNATURE_TYPE=1
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Bankroll
STARTING_BANKROLL=10.0
MIN_BET=5.0
MAX_BET=25.0

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
